# --- LLM provider (provider-agnostic client) ---
# Which provider to use: openai | groq | ollama | gemini
LLM_PROVIDER=openai

# API key for the selected provider (not needed for ollama)
LLM_API_KEY=sk-your-key-here

# Optional: override the base URL (e.g. Groq / OpenRouter / local Ollama)
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Model used for planning/selection (can be smaller/faster)
LLM_PLANNER_MODEL=gpt-4o-mini
# Model used for codegen + self-repair (use the strongest coding model)
LLM_CODER_MODEL=gpt-4o
# Avoid frozen demo runs when a provider is slow or unreachable.
LLM_TIMEOUT_SECONDS=20

# --- Engine ---
# Max self-repair retries during tool synthesis
MAX_REPAIR_RETRIES=3
# Sandbox execution timeout (seconds)
SANDBOX_TIMEOUT_SECONDS=10

# --- Persistence ---
# Registry backend: sqlite | json
REGISTRY_BACKEND=sqlite
REGISTRY_PATH=data/mycelium.db

# --- CORS (frontend origin) ---
# Local dev also allows localhost/127.0.0.1 on ports 3000 and 3001 in code.
FRONTEND_ORIGIN=http://localhost:3000
